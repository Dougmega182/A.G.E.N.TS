{
  "id": "decision_v1",
  "type": "object",
  "required": ["decision", "justification", "conditions", "impact", "confidence_score", "confidence_reason"],
  "properties": {
    "decision": { "type": "string", "enum": ["APPROVE", "REJECT", "ESCALATE"] },
    "confidence_score": { 
      "type": "number", 
      "minimum": 0, 
      "maximum": 1,
      "description": "0.0 to 1.0 based on structural integrity, governance flags, and Owen intel utilization."
    },
    "confidence_reason": {
      "type": "string",
      "description": "Explanation of why the confidence score is high or low."
    },
    "justification": { 
      "type": "string", 
      "minLength": 20,
      "description": "Must reference the risk_score, Sentinel critique, and risk_trend."
    },
    "conditions": { "type": "array", "items": { "type": "string" } },
    "impact": {
      "type": "object",
      "required": ["cost", "days", "risk_delta"],
      "properties": {
        "cost": { "type": "number" },
        "days": { "type": "integer" },
        "risk_delta": { "type": "number" }
      }
    }
  }
}
